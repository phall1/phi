{
  "name": "oh-my-pi",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi package: ergonomic frontend extensions, themes, prompts, and skills.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "tui"
  ],
  "type": "module",
  "scripts": {
    "dev": "pi --extension ./extensions/zen-shell.ts",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "themes": [
      "./themes"
    ]
  }
}
